{
  "name": "skills-factory-cx",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev:api": "npm --workspace @skills/market-api run dev",
    "dev:worker": "npm --workspace @skills/ingest-worker run dev",
    "dev:cli": "npm --workspace find-skills run dev",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
